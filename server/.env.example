NODE_ENV=development
PORT=5000
MONGO_URI=mongodb://127.0.0.1:27017/goovoiture
JWT_SECRET=change_this_to_a_long_random_secret_at_least_32_chars

# Email (Nodemailer)
EMAIL_HOST=smtp.gmail.com
EMAIL_PORT=587
EMAIL_USER=your_email@gmail.com
EMAIL_PASS=your_app_password
EMAIL_FROM="Goovoiture <your_email@gmail.com>"

# Client URL (for CORS + email links)
CLIENT_URL=http://localhost:5173
APP_URL=goovoiture://

# Cloudinary — REQUIRED for image uploads (avatars, listings, license/CIN photos).
# Do not leave the "your_*" placeholders; copy real values from:
# https://console.cloudinary.com → Dashboard (Cloud name, API key, API secret)
CLOUDINARY_CLOUD_NAME=your_cloud_name
CLOUDINARY_API_KEY=your_api_key
CLOUDINARY_API_SECRET=your_api_secret

# WhatsApp (Meta Cloud API) — optional but recommended for Morocco market
# Setup: developers.facebook.com → Create App → Add WhatsApp product
# 1. Copy "Temporary access token" → META_WHATSAPP_TOKEN
# 2. Copy "Phone number ID"        → META_PHONE_NUMBER_ID
# Test mode: add up to 5 recipient numbers in the Meta dashboard (free, instant)
META_WHATSAPP_TOKEN=EAA_placeholder
META_PHONE_NUMBER_ID=your_phone_number_id
