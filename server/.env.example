NODE_ENV=development
PORT=5000
MONGO_URI=mongodb://127.0.0.1:27017/goovoiture
JWT_SECRET=change_this_to_a_long_random_secret_at_least_32_chars

# Email (Nodemailer)
EMAIL_HOST=smtp.gmail.com
EMAIL_PORT=587
EMAIL_USER=your_email@gmail.com
EMAIL_PASS=your_app_password
EMAIL_FROM="Goovoiture <your_email@gmail.com>"

# Client URL (for CORS + email links)
CLIENT_URL=http://localhost:5173

# Cloudinary (create a free account at cloudinary.com)
CLOUDINARY_CLOUD_NAME=your_cloud_name
CLOUDINARY_API_KEY=your_api_key
CLOUDINARY_API_SECRET=your_api_secret
