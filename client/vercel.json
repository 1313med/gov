{
  "framework": "vite",
  "rewrites": [{ "source": "/(.*)", "destination": "/index.html" }],
  "redirects": [
    { "source": "/location-voiture-occasion/:city", "destination": "/voiture-occasion/:city", "permanent": true },
    { "source": "/en/location-voiture-occasion/:city", "destination": "/en/voiture-occasion/:city", "permanent": true },
    { "source": "/ar/location-voiture-occasion/:city", "destination": "/ar/voiture-occasion/:city", "permanent": true }
  ],
  "headers": [
    {
      "source": "/sitemap.xml",
      "headers": [{ "key": "Content-Type", "value": "application/xml; charset=utf-8" }]
    },
    {
      "source": "/sitemap-index.xml",
      "headers": [{ "key": "Content-Type", "value": "application/xml; charset=utf-8" }]
    },
    {
      "source": "/sitemaps/(.*)",
      "headers": [{ "key": "Content-Type", "value": "application/xml; charset=utf-8" }]
    },
    {
      "source": "/robots.txt",
      "headers": [{ "key": "Content-Type", "value": "text/plain; charset=utf-8" }]
    }
  ]
}
