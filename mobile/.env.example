# Local API when developing on a physical device (same Wi‑Fi as your PC).
# After you change Wi‑Fi, run `ipconfig` and set this to your PC’s IPv4, e.g. http://192.168.0.15:5000
EXPO_PUBLIC_DEV_API_URL=http://192.168.1.27:5000

# OAuth client IDs (must match server provider console settings)
EXPO_PUBLIC_GOOGLE_WEB_CLIENT_ID=
EXPO_PUBLIC_GOOGLE_IOS_CLIENT_ID=
EXPO_PUBLIC_GOOGLE_ANDROID_CLIENT_ID=
EXPO_PUBLIC_FACEBOOK_APP_ID=
